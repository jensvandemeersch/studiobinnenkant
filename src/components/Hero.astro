---
---

<section class="hero">
  <img
    src="/images/hero.webp"
    srcset="/images/hero-mobile.webp 768w, /images/hero.webp 1920w"
    sizes="100vw"
    alt="Studio Binnenkant — sculpturaal interieurontwerp"
    class="hero__bg"
    width="1920"
    height="1080"
    loading="eager"
    decoding="sync"
    fetchpriority="high"
  />
  <div class="hero__overlay"></div>
  <div class="hero__content">
    <h1 class="hero__title">
      Sculpturaal interieurontwerp,<br />
      <em>architecturaal doordacht.</em>
    </h1>
    <p class="hero__sub">
      Interieurs ontworpen als architecturale volumes —<br />
      van concept tot installatie.
    </p>
    <a href="/contact" class="hero__cta">Een project bespreken</a>
  </div>

  <a href="#projecten" class="hero__scroll" aria-label="Scroll naar projecten">
    <span class="hero__scroll-label">Ontdek projecten</span>
    <span class="hero__scroll-line"></span>
  </a>
</section>

<style>
  .hero {
    min-height: 88svh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 0 2.5rem 5rem;
    position: relative;
    overflow: hidden;
    background: #f5f0e8;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        to right,
        rgba(245, 240, 232, 0) 55%,
        rgba(245, 240, 232, 0.55) 100%
      ),
      linear-gradient(
        to top,
        rgba(245, 240, 232, 0.85) 0%,
        rgba(245, 240, 232, 0.4) 50%,
        rgba(245, 240, 232, 0.05) 100%
      );
    z-index: 1;
  }

  .hero__content {
    position: relative;
    z-index: 2;
    max-width: 800px;
  }

  .hero__title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 300;
    line-height: 1.05;
    color: #0d0d0d;
    margin: 0 0 1.5rem;
    letter-spacing: -0.01em;
  }

  .hero__title em {
    font-style: italic;
    color: #6b5c45;
  }

  .hero__sub {
    font-family: 'DM Mono', monospace;
    font-size: 0.8rem;
    font-weight: 300;
    line-height: 1.8;
    color: rgba(13, 13, 13, 0.55);
    letter-spacing: 0.04em;
    margin: 0 0 2.5rem;
  }

  .hero__cta {
    display: inline-block;
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    font-weight: 400;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #f5f0e8;
    background: #0d0d0d;
    text-decoration: none;
    padding: 0.9rem 1.8rem;
    transition: background 0.25s, color 0.25s;
  }

  .hero__cta:hover {
    background: #6b5c45;
    color: #f5f0e8;
  }

  /* Scroll indicator — gecentreerd onderaan */
  .hero__scroll {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    color: rgba(13, 13, 13, 0.5);
    transition: color 0.25s;
  }

  .hero__scroll:hover {
    color: #6b5c45;
  }

  .hero__scroll-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    animation: labelFade 2.8s ease-in-out infinite;
  }

  .hero__scroll-line {
    display: block;
    width: 1px;
    height: 48px;
    background: currentColor;
    transform-origin: top center;
    animation: lineGrow 2.8s ease-in-out infinite;
  }

  @keyframes labelFade {
    0%, 100% { opacity: 0.5; }
    50% { opacity: 1; }
  }

  @keyframes lineGrow {
    0% { transform: scaleY(0); opacity: 0; }
    30% { opacity: 1; }
    70% { transform: scaleY(1); opacity: 1; }
    100% { transform: scaleY(1); opacity: 0; }
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 88svh;
      padding: 0 1.5rem 5rem;
    }

    .hero__bg {
      object-position: 35% top;
    }

    .hero__scroll {
      display: none;
    }

    .hero__sub br {
      display: none;
    }

    .hero__title {
      font-size: clamp(2rem, 10vw, 3rem);
    }

    .hero__cta {
      width: 100%;
      text-align: center;
      padding: 1rem;
    }


  }
</style>

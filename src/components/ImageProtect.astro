<style is:global>
  img {
    pointer-events: none;
    user-select: none;
    -webkit-user-drag: none;
    -khtml-user-drag: none;
    -moz-user-drag: none;
    -o-user-drag: none;
  }

  * {
    user-select: none;
    -webkit-user-select: none;
  }

  /* Tekst in meta en titels wél selecteerbaar laten */
  p, h1, h2, h3, a {
    user-select: text;
    -webkit-user-select: text;
  }
</style>

<script>
  // Blokkeer rechtermuisklik
  document.addEventListener('contextmenu', e => e.preventDefault());

  // Blokkeer Ctrl+S / Cmd+S (opslaan)
  document.addEventListener('keydown', e => {
    if ((e.ctrlKey || e.metaKey) && e.key === 's') {
      e.preventDefault();
    }
    // Blokkeer Ctrl+U / Cmd+U (broncode bekijken)
    if ((e.ctrlKey || e.metaKey) && e.key === 'u') {
      e.preventDefault();
    }
  });

  // Blokkeer drag van afbeeldingen
  document.addEventListener('dragstart', e => {
    if (e.target.tagName === 'IMG') {
      e.preventDefault();
    }
  });
</script>

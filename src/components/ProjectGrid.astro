---
interface Project {
  title: string;
  slug: string;
  image: string;
  category: string;
}

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;
---

<section class="projects">
  <div class="projects__grid">
    {projects.map((project, index) => (
      <a
        href={`/projecten/${project.slug}/`}
        class="project-card"
        data-category={project.category}
      >
        <div class="project-card__image-wrap">
          <img
            src={project.image}
            alt={`${project.title} — Studio Binnenkant`}
            loading={index < 6 ? 'eager' : 'lazy'}
            decoding="async"
            width="800"
            height="600"
            class="project-card__image"
          />
        </div>
        <div class="project-card__meta">
          <h2 class="project-card__title">{project.title}</h2>
          <span class="project-card__link">Bekijk project</span>
        </div>
      </a>
    ))}
  </div>
</section>

<style>
  .projects {
    background: #fff;
    padding: 60px 60px 100px;
    max-width: 1600px;
    margin: 0 auto;
  }

  .projects__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 60px 40px;
  }

  .project-card {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .project-card__image-wrap {
    overflow: hidden;
    aspect-ratio: 3 / 4;
    background: #e8e8e8;
    margin-bottom: 14px;
  }

  .project-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .project-card:hover .project-card__image {
    transform: scale(1.03);
  }

  .project-card__meta {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
  }

  .project-card__title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1rem;
    font-weight: 400;
    color: #111;
    margin: 0;
  }

  .project-card__link {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    font-weight: 300;
    letter-spacing: 0.06em;
    color: #888;
    text-decoration: underline;
    white-space: nowrap;
  }

  @media (max-width: 900px) {
    .projects {
      padding: 40px 20px 70px;
    }
    .projects__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px 16px;
    }
    .project-card__title {
      font-size: 0.9rem;
    }
    .project-card__link {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .projects {
      padding: 24px 16px 60px;
    }
    .projects__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px 12px;
    }
  }
</style>

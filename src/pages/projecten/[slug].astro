---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();
const { title, category, image, description, details, render } = project.data;

// Haal secties uit markdown body
const rawContent = project.body;
const openingszinMatch = rawContent.match(/## Openingszin\s*\n+([^\n#][^\n]+(?:\n(?![#])[^\n]+)*)/);
const openingszin = openingszinMatch ? openingszinMatch[1].trim() : null;

const omschrijvingMatch = rawContent.match(/## Projectomschrijving\s*\n+([\s\S]*?)(?=\n## |$)/);
const omschrijving = omschrijvingMatch ? omschrijvingMatch[1].trim() : null;

const specificatiesMatch = rawContent.match(/## Specificaties\s*\n+([\s\S]*?)(?=\n## |$)/);
const specificatiesRaw = specificatiesMatch ? specificatiesMatch[1].trim() : null;
// Parse bullet list naar array van {label, value}
const linksLabels = ['type', 'locatie', 'materialen'];
const specificatiesRaw2 = specificatiesRaw
  ? specificatiesRaw.split('\n').filter(l => l.startsWith('-')).map(l => {
      const clean = l.replace(/^-\s*/, '').replace(/\*\*/g, '');
      const colonIdx = clean.indexOf(':');
      return colonIdx > -1
        ? { label: clean.slice(0, colonIdx).trim(), value: clean.slice(colonIdx + 1).trim() }
        : { label: '', value: clean };
    })
  : [];
const specsLinks = specificatiesRaw2.filter(s => linksLabels.includes(s.label.toLowerCase()));
const specsRechts = specificatiesRaw2.filter(s => !linksLabels.includes(s.label.toLowerCase()));
// Combineer: links dan rechts afwisselend per rij
const maxRows = Math.max(specsLinks.length, specsRechts.length);
const specificaties = Array.from({ length: maxRows }, (_, i) => ({
  left: specsLinks[i] ?? null,
  right: specsRechts[i] ?? null,
}));

// Haal de mapnaam en hero-pad op
const imageFolder = image.split('/')[2];
const heroImage = `/images/${imageFolder}/hero.webp`;

// Ondersteunt zowel "Label: waarde" strings als {label, value} objecten
const parsedDetails = details?.map((item: any) => {
  if (typeof item === 'string') {
    const colonIndex = item.indexOf(':');
    return {
      label: item.slice(0, colonIndex).trim(),
      value: item.slice(colonIndex + 1).trim(),
    };
  }
  return item;
}) ?? [];

const allProjects = await getCollection('projects');
const sorted = allProjects.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
const currentIndex = sorted.findIndex((p) => p.slug === project.slug);
const prev = sorted[currentIndex + 1] ?? sorted[0];
const next = currentIndex === 0 ? sorted[sorted.length - 1] : sorted[currentIndex - 1];
---

<BaseLayout title={title} description={description ?? `${title} – Studio Binnenkant`}>
  <article class="project-detail">

    <!-- HERO SECTION: 2 kolommen -->
    <section class="hero-section">
      <div class="hero-image">
        <img src={heroImage} alt={title} width="800" height="1067" loading="eager" />
      </div>
      <div class="hero-info">
        <p class="category">{category}</p>
        <h1>{title}</h1>
        {openingszin && <p class="openingszin">{openingszin}</p>}
        {omschrijving && (
          <div class="omschrijving">
            {omschrijving.split(/\n\n+/).map((para: string) => (
              <p>{para.trim()}</p>
            ))}
          </div>
        )}
        <!-- SCROLL HINT -->
        <div class="scroll-hint" id="scrollHint">
          <span class="scroll-hint__text">Meer foto's</span>
          <svg class="scroll-hint__arrow" width="16" height="24" viewBox="0 0 16 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <line x1="8" y1="0" x2="8" y2="20" stroke="#6b5c45" stroke-width="1"/>
            <polyline points="2,14 8,22 14,14" stroke="#6b5c45" stroke-width="1" fill="none"/>
          </svg>
        </div>
      </div>
    </section>

    <!-- SPECS -->
    {specificaties.length > 0 && (
      <section class="specs-section">
        <p class="specs-label">Specificaties</p>
        <div class="specs-grid">
          {specificaties.map((row: { left: any; right: any }) => (
            <>
              <span class="spec-label">{row.left?.label ?? ''}</span>
              <span class="spec-value">{row.left?.value ?? ''}</span>
              <span class="spec-label">{row.right?.label ?? ''}</span>
              <span class="spec-value">{row.right?.value ?? ''}</span>
            </>
          ))}
        </div>
      </section>
    )}

    <!-- RENDER -->
    {render && (
      <section class="render-section">
        <p class="render-label">Ontwerpfase</p>
        <img
          src={render}
          alt={`${title} — render`}
          class="render-image"
          loading="lazy"
        />
      </section>
    )}

    <!-- GALLERY: detail afbeeldingen op basis van image-map -->
    <section class="gallery-section">
      <div class="gallery-grid">
        {[1,2,3,4].map((i) => (
          <div class="gallery-item">
            <img
              src={`/images/${imageFolder}/detail${i}.webp`}
              alt={`${title} detail ${i}`}
              width="1200"
              height="900"
              loading="lazy"
              style="width:100%;height:auto;aspect-ratio:4/3;object-fit:cover;"
            />
          </div>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-section">
      <p class="cta-label">Interesse in een gelijkaardig project?</p>
      <a href="/contact" class="cta-link">Neem contact op</a>
    </section>

    <!-- PAGER -->
    <nav class="pager">
      {prev ? (
        <a href={`/projecten/${prev.slug}`} class="pager-link prev">
          <span class="arrow">←</span>
          <span class="pager-label">
            <span class="pager-hint">Vorig project</span>
            <span class="pager-title">{prev.data.title}</span>
          </span>
        </a>
      ) : <div />}
      <a href="/" class="pager-home">Alle projecten</a>
      {next ? (
        <a href={`/projecten/${next.slug}`} class="pager-link next">
          <span class="pager-label">
            <span class="pager-hint">Volgend project</span>
            <span class="pager-title">{next.data.title}</span>
          </span>
          <span class="arrow">→</span>
        </a>
      ) : <div />}
    </nav>

  </article>
</BaseLayout>

<style>
  .project-detail {
    border-top: 1px solid #ccc;
    max-width: 1400px;
    margin: 0 auto;
    padding: 90px 40px 100px;
  }

  /* HERO */
  .hero-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: start;
    margin-top: 20px;
    margin-bottom: 60px;
  }

  .hero-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .hero-info {
    position: sticky;
    top: 80px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    align-self: start;
  }

  .category {
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #999;
    margin: 0;
  }

  .hero-info h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 400;
    line-height: 1.1;
    margin: 0;
    color: #2a2520;
  }

  .openingszin {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.2rem;
    font-style: italic;
    color: #6b5c45;
    margin: 0;
    line-height: 1.6;
  }

  /* SCROLL HINT */
  .scroll-hint {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 10px;
    margin-top: auto;
    padding-top: 2rem;
    opacity: 1;
    transition: opacity 0.6s ease;
  }

  .scroll-hint.hidden {
    opacity: 0;
    pointer-events: none;
  }

  .scroll-hint__text {
    font-family: 'DM Mono', monospace;
    font-size: 0.62rem;
    font-weight: 300;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #888;
  }

  .scroll-hint__arrow {
    animation: scrollBounce 1.8s ease-in-out infinite;
    display: block;
  }

  @keyframes scrollBounce {
    0%, 100% { transform: translateY(0); opacity: 1; }
    50% { transform: translateY(5px); opacity: 0.4; }
  }

  /* OMSCHRIJVING naast hero */
  .omschrijving {
    border-top: 1px solid #ccc;
    padding-top: 20px;
  }

  .omschrijving p {
    font-size: 0.95rem;
    line-height: 1.85;
    color: #555;
    margin: 0 0 1em;
  }

  .omschrijving p:last-child {
    margin-bottom: 0;
  }

  /* SPECS sectie onder hero */
  .specs-section {
    margin-bottom: 80px;
    border-top: 1px solid #ccc;
    padding-top: 60px;
  }

  .specs-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #666;
    margin: 0 0 20px;
  }

  .specs-grid {
    display: grid;
    grid-template-columns: 100px 1fr 100px 1fr;
    gap: 0 60px;
  }

  .spec-row {
    display: contents;
  }

  .spec-label {
    font-family: 'DM Mono', monospace;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.67rem;
    padding: 8px 0;
    align-self: baseline;
  }

  .spec-value {
    color: #111;
    font-size: 0.88rem;
    line-height: 1.5;
    padding: 8px 0;
    align-self: baseline;
  }

  /* RENDER */
  .render-section {
    border-top: 1px solid #ccc;
    padding-top: 60px;
    margin-bottom: 80px;
  }

  .render-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #666;
    margin: 0 0 20px;
  }

  .render-image {
    width: 100%;
    height: auto;
    display: block;
  }

  /* GALLERY */
  .gallery-section {
    border-top: 1px solid #ccc;
    padding-top: 60px;
    margin-bottom: 80px;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .gallery-item img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
  }

  /* CTA */
  .cta-section {
    border-top: 1px solid #ccc;
    padding-top: 60px;
    margin-bottom: 60px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 28px;
  }

  .cta-label {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.4rem;
    font-style: italic;
    color: #333;
    margin: 0;
  }

  .cta-link {
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #fff;
    background: #111;
    text-decoration: none;
    border: 1px solid #111;
    padding: 14px 28px;
    transition: all 0.2s;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .cta-link:hover {
    background: transparent;
    color: #111;
  }

  /* PAGER */
  .pager {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid #ccc;
    padding-top: 40px;
    gap: 20px;
  }

  .pager-link {
    display: flex;
    align-items: center;
    gap: 16px;
    text-decoration: none;
    color: inherit;
    transition: opacity 0.2s;
    min-height: 44px;
    padding: 8px 0;
  }

  .pager-link:hover { opacity: 0.6; }

  .pager-label {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .pager-hint {
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #aaa;
  }

  .pager-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    color: #111;
  }

  .next .pager-label { text-align: right; }

  .arrow { font-size: 1.25rem; color: #aaa; }

  .pager-home {
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #888;
    text-decoration: none;
    border: 1px solid #ddd;
    padding: 10px 20px;
    transition: all 0.2s;
    white-space: nowrap;
  }

  .pager-home:hover {
    background: #111;
    color: #fff;
    border-color: #111;
  }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .project-detail {
      padding: 80px 24px 80px;
    }
    .hero-section {
      grid-template-columns: 1fr;
      gap: 28px;
      margin-top: 12px;
      margin-bottom: 40px;
    }
    .hero-info { position: static; }
    .hero-image img {
      max-height: 70vw;
      object-fit: cover;
    }
    .gallery-grid {
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }
    .specs-grid {
      grid-template-columns: 90px 1fr;
      gap: 0 20px;
    }
    .specs-section {
      padding-top: 40px;
    }
    .render-section {
      padding-top: 40px;
    }
    .gallery-section {
      padding-top: 40px;
    }
    .cta-section {
      padding-top: 40px;
    }
    .cta-label {
      font-size: 1.15rem;
    }
    .pager {
      gap: 16px;
    }
    .pager-home {
      padding: 8px 14px;
      font-size: 0.65rem;
    }
  }

  @media (max-width: 600px) {
    .project-detail {
      padding: 72px 16px 60px;
    }
    .gallery-grid {
      grid-template-columns: 1fr;
      gap: 12px;
    }
    .specs-grid {
      grid-template-columns: 80px 1fr;
      gap: 0 16px;
    }
    .pager {
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
    }
    .pager-home {
      align-self: center;
    }
    .omschrijving p {
      font-size: 0.88rem;
    }
  }
</style>

<script>
  const hint = document.getElementById('scrollHint');
  if (hint) {
    const onScroll = () => {
      if (window.scrollY > 80) {
        hint.classList.add('hidden');
        window.removeEventListener('scroll', onScroll);
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>